{
  "extends": "./node_modules/@sentry/typescript/tsconfig.json",
  "include": [
    "./src/js/*.ts",
    "./src/js/*.tsx",
    "./src/js/playground/*.ts",
    "./src/js/playground/*.tsx",
    "./src/js/**/*.web.ts",
    "./src/js/**/*.web.tsx",
    "./typings/react-native.d.ts",
    "./typings/global.d.ts"
  ],
  "exclude": ["node_modules"],
  "compilerOptions": {
    // @sentry/typescript@10.59.0 switched its base config to `moduleResolution: bundler`,
    // which honors `react-native`'s exports map and fails to resolve subpaths like
    // `react-native/types`. Pin classic node resolution to keep these imports working.
    "moduleResolution": "node",
    "paths": {
      "metro": ["./node_modules/metro/src/index"],
      // `@sentry/bundler-plugins` exposes the component-annotate plugin via the `./babel-plugin`
      // subpath export, which classic `node` resolution can't follow. Point directly at its types.
      "@sentry/bundler-plugins/babel-plugin": [
        "./node_modules/@sentry/bundler-plugins/build/types/babel-plugin/index.d.ts"
      ]
    },
    "outDir": "dist",
    "rootDir": "src",
    "lib": [
      "es7"
    ],
    "jsx": "react",
    "types": [
      "react-native"
    ],
    "target": "es6",
    "module": "es6",
    "skipLibCheck": true,
    "strictBindCallApply": true,
    "importHelpers": false
  }
}
