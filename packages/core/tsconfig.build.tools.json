{
  "extends": "./node_modules/@sentry/typescript/tsconfig.json",
  "include": ["./src/js/tools/**/*.ts"],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "baseUrl": ".",
    // @sentry/typescript@10.59.0 base config sets `moduleResolution: bundler`, which is
    // incompatible with `module: CommonJS` below. Pin classic node resolution.
    "moduleResolution": "node",
    "paths": {
      "metro": ["./node_modules/metro/src/index"]
    },
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["es7"],
    "types": ["node"],
    "target": "es6",
    "module": "CommonJS",
    "skipLibCheck": true,
    "importHelpers": false
  }
}
